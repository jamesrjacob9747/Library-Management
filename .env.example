# ── Database Configuration (PostgreSQL) ──────────────────────────────
# Used by both Docker Compose and Prisma
DB_NAME=library_management
DB_USER=postgres
DB_PASSWORD=your_secure_password_here_change_me

# ── API Authentication ───────────────────────────────────────────────
# Must be at least 20 characters in production
API_KEY=your_super_secret_api_key_12345_change_me_in_production

# ── Node Environment ─────────────────────────────────────────────────
NODE_ENV=production
